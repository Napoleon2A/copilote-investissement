# Copilote Investissement — Configuration backend
# Copie ce fichier en .env et adapte les valeurs.
# Le fichier .env ne doit PAS être commité (il est dans .gitignore).

# Base de données (SQLite local — ne rien changer en dev)
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Mode debug (false en production)
API_DEBUG=false

# CORS — pour autoriser ton frontend Vercel à appeler l'API
# Exemple : ALLOWED_ORIGINS=https://mon-app.vercel.app
ALLOWED_ORIGINS=
