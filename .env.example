# ─── Base de données ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_platform
POSTGRES_USER=trading
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql+asyncpg://trading:changeme@localhost:5432/trading_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
SECRET_KEY=change-this-secret-key-in-production

# ─── Providers de données ─────────────────────────────────────────────────────
# Provider actif : yfinance (gratuit) | fmp | alphavantage
MARKET_DATA_PROVIDER=yfinance
FUNDAMENTALS_PROVIDER=yfinance
NEWS_PROVIDER=yfinance

# Financial Modeling Prep (optionnel - V2)
# FMP_API_KEY=your_fmp_key_here

# Alpha Vantage (optionnel - V2)
# ALPHA_VANTAGE_API_KEY=your_av_key_here

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
MARKET_DATA_REFRESH_MINUTES=15
FUNDAMENTALS_REFRESH_HOURS=24

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Copilote Investissement

# ─── Alertes (optionnel - V2) ────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
